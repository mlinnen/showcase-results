{{!-- article.hbs — Frodo
     Joomla article body template. No <html>/<head>/<body> wrappers.
     No inline styles. No <script> tags.
--}}

<h2>{{event.name}} {{event.year}} — Showcase Results</h2>

{{!-- Prize Results by Category --}}
{{#each categories}}
<h3>{{this.name}}</h3>
<table class="showcase-prizes">
  <thead>
    <tr>
      <th>Place</th>
      <th>Ribbon</th>
      <th>Winner</th>
      <th>Entry</th>
    </tr>
  </thead>
  <tbody>
    {{#each this.prizes}}
    <tr>
      <td>{{this.place}}</td>
      <td>{{this.ribbon}}</td>
      <td>{{this.winner}}</td>
      <td>{{this.entry}}</td>
    </tr>
    {{/each}}
  </tbody>
</table>
{{/each}}

{{!-- Competitors Summary --}}
<h3>Competitors</h3>
<table class="showcase-competitors">
  <thead>
    <tr>
      <th>Competitor</th>
      <th>Category</th>
      <th>Place</th>
      <th>Ribbon</th>
    </tr>
  </thead>
  <tbody>
    {{#each competitors}}
      {{#each this.ribbons}}
      <tr>
        <td>{{../name}}</td>
        <td>{{this.category}}</td>
        <td>{{this.place}}</td>
        <td>{{this.ribbon}}</td>
      </tr>
      {{/each}}
    {{/each}}
  </tbody>
</table>
