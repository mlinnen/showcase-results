{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "results.schema.json",
  "title": "ShowcaseResults",
  "description": "Normalized output from Bilbo's spreadsheet parser. Consumed by Frodo's article renderer.",
  "type": "object",
  "required": ["event", "categories", "competitors"],
  "additionalProperties": false,
  "properties": {
    "event": {
      "type": "object",
      "required": ["name", "year"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "year": { "type": "integer", "minimum": 2000 }
      }
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "prizes"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "prizes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["place", "ribbon", "winner"],
              "additionalProperties": false,
              "properties": {
                "place":  { "type": "integer", "minimum": 1 },
                "ribbon": { "type": "string", "minLength": 1 },
                "winner": { "type": "string", "minLength": 1 },
                "entry":  { "type": "string" }
              }
            }
          }
        }
      }
    },
    "competitors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "ribbons"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "ribbons": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["category", "place", "ribbon"],
              "additionalProperties": false,
              "properties": {
                "category": { "type": "string", "minLength": 1 },
                "place":    { "type": "integer", "minimum": 1 },
                "ribbon":   { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    }
  }
}
